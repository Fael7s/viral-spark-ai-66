# Variáveis de ambiente do ViralCaption
# Copie para .env e preencha os valores. NUNCA use o prefixo VITE_ para segredos.

# --- Supabase / Lovable Cloud (gerenciado automaticamente) ---
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=

# --- Stripe (server-side apenas) ---
# Chave secreta da API do Stripe (sk_live_... ou sk_test_...)
STRIPE_SECRET_KEY=
# Segredo de assinatura do endpoint de webhook (whsec_...)
STRIPE_WEBHOOK_SECRET=
# ID do preço da assinatura mensal do plano Pro (price_...)
STRIPE_PRICE_ID_PRO=

# --- Origem confiável para redirects de checkout/portal ---
# Defina APP_ORIGIN em produção para evitar host header injection.
APP_ORIGIN=https://seu-dominio.com
# Alternativa: lista de hosts permitidos separados por vírgula.
ALLOWED_HOSTS=seu-dominio.com,localhost
